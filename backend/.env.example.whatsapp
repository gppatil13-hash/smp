# WhatsApp Business API Configuration Example
# Copy to .env and fill in your actual values

# ============================================================
# WhatsApp Business API
# ============================================================

# Your WhatsApp Business API Access Token
# Get from: https://developers.facebook.com/apps/
WHATSAPP_ACCESS_TOKEN=your_access_token_here

# Your WhatsApp Business Account ID
# Get from: https://www.facebook.com/business/
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# Your WhatsApp Phone Number ID
# The ID of the phone number you created in WhatsApp Business Account
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# WhatsApp API Version (default: v18.0)
WHATSAPP_API_VERSION=v18.0

# Webhook Verification Token
# Create a unique token for webhook verification
# Must match the token configured in Meta's Webhook settings
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_unique_webhook_token_here

# Optional: Enable/disable WhatsApp messaging
WHATSAPP_ENABLED=true

# Optional: Default language for templates
WHATSAPP_DEFAULT_LANGUAGE=en_US

# Optional: Message retry configuration
WHATSAPP_MAX_RETRIES=3
WHATSAPP_RETRY_DELAY_MS=5000
WHATSAPP_RETRY_BACKOFF_MULTIPLIER=2

# Optional: Logging
WHATSAPP_LOG_LEVEL=info
WHATSAPP_LOG_FILE=./logs/whatsapp.log
