          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"parent@example.com\",\n  \"subject\": \"Admission Confirmation\",\n  \"body\": \"<h2>Welcome!</h2><p>Your ward's admission has been confirmed. Please visit our office for enrollment.</p>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admissions/{{admission_id}}/send-email",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admissions", "{{admission_id}}", "send-email"]
            }
          }
        },
        {
          "name": "Send Status Notification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ADMITTED\",\n  \"parentPhone\": \"+919876543210\",\n  \"parentEmail\": \"parent@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admissions/{{admission_id}}/notify-status",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admissions", "{{admission_id}}", "notify-status"]
            }
          }
        },
        {
          "name": "Send Follow-up Reminder",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"parentPhone\": \"+919876543210\",\n  \"parentEmail\": \"parent@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/admissions/enquiry/{{enquiry_id}}/send-reminder",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "admissions", "enquiry", "{{enquiry_id}}", "send-reminder"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "your-jwt-token-here",
      "type": "string"
    },
    {
      "key": "enquiry_id",
      "value": "enquiry-uuid",
      "type": "string"
    },
    {
      "key": "admission_id",
      "value": "admission-uuid",
      "type": "string"
    },
    {
      "key": "student_id",
      "value": "student-uuid",
      "type": "string"
    },
    {
      "key": "document_id",
      "value": "document-uuid",
      "type": "string"
    },
    {
      "key": "class_id",
