# ------------------------
# Backend Environment
# ------------------------
DATABASE_URL=postgresql://school_erp_user:strongpassword@school-erp-db:5432/school_erp
JWT_SECRET=your_prod_jwt_secret
JWT_EXPIRY=30d
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://erp.yourschool.edu

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_S3_BUCKET=your-production-s3-bucket

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your@domain.com
SMTP_PASSWORD=your_smtp_password

# Twilio/WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token

# ------------------------
# Frontend Environment
# ------------------------
NEXT_PUBLIC_API_URL=https://api.yourschool.edu
NEXT_PUBLIC_APP_URL=https://erp.yourschool.edu

# ------------------------
# Database Role (for migrations)
# ------------------------
DB_USER=school_erp_user
DB_PASSWORD=strongpassword
DB_NAME=school_erp
